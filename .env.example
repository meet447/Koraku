# Copy to .env and configure your preferred LLM backend and premium tools

# --- LLM Provider ---
# Options: fireworks (recommended), custom_openai, anthropic, demo
LLM_PROVIDER=fireworks

# --- Option 1: Fireworks AI (recommended — fast, high-quality models) ---
FIREWORKS_API_KEY=your-fireworks-key
# Available models:
#   accounts/fireworks/models/kimi-k2p6
#   accounts/fireworks/models/minimax-m2p7
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p6

# --- Option 2: Prism/Bonsai (free, no API key) — OpenAI-compatible /v1/chat/completions ---
# LLM_PROVIDER=custom_openai
# CUSTOM_BASE_URL=https://prism-ml-bonsai-demo.hf.space/v1
# Models (see also GET .../v1/models on the Space): Bonsai-8B-Q1_0, Ternary-Bonsai-8B-Q2_0
# CUSTOM_MODEL=Ternary-Bonsai-8B-Q2_0

# --- Option 3: Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Option 4: Any other OpenAI-compatible endpoint ---
# CUSTOM_BASE_URL=http://localhost:1234/v1
# CUSTOM_MODEL=llama-3.3-70b

# --- Premium Tools (optional) ---
EXA_API_KEY=your-exa-key
FIRECRAWL_API_KEY=your-firecrawl-key

# --- Composio (Skills: Gmail, Google Drive, Slack, …) ---
# Get a key at https://app.composio.dev — must live in the **Python backend** env / repo-root .env
# (the Next.js app only proxies to the backend; it does not read this file).
COMPOSIO_API_KEY=your-composio-api-key
# Optional: separate identities when running multiple Koraku profiles against one Composio project
# COMPOSIO_USER_ID=koraku-local

# --- Context (optional) ---
# Larger tool payloads (e.g. verbose Composio Gmail) need a higher cap before truncation on the next model turn.
# MAX_TOOL_RESULT_CHARS=48000

PORT=8000

# --- Blaxel (optional — isolated VM for chat ``execution_target=cloud``) ---
# https://docs.blaxel.ai/Sandboxes/Overview — create keys in the Blaxel console.
# Koraku copies BL_WORKSPACE + BL_API_KEY from this file into the process environment so the Blaxel SDK sees them.
# BLAXEL_CLOUD_SANDBOX_ENABLED=true
# BL_WORKSPACE=your-workspace
# BL_API_KEY=your-api-key
# BLAXEL_SANDBOX_IMAGE=blaxel/base-image:latest
# BLAXEL_SANDBOX_REGION=us-pdx-1
# BLAXEL_SANDBOX_MEMORY_MB=512
# BLAXEL_SANDBOX_WORKDIR=/tmp

