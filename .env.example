# Copy to .env and configure your preferred LLM backend and premium tools

# --- LLM Provider ---
# Options: fireworks (recommended), custom_openai, anthropic, demo
LLM_PROVIDER=fireworks

# --- Option 1: Fireworks AI (recommended — fast, high-quality models) ---
FIREWORKS_API_KEY=your-fireworks-key
# Available models:
#   accounts/fireworks/models/kimi-k2p6
#   accounts/fireworks/models/minimax-m2p7
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p6

# --- Option 2: Prism/Bonsai (free, no API key) — OpenAI-compatible /v1/chat/completions ---
# LLM_PROVIDER=custom_openai
# CUSTOM_BASE_URL=https://prism-ml-bonsai-demo.hf.space/v1
# Models (see also GET .../v1/models on the Space): Bonsai-8B-Q1_0, Ternary-Bonsai-8B-Q2_0
# CUSTOM_MODEL=Ternary-Bonsai-8B-Q2_0

# --- Option 3: Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Option 4: Any other OpenAI-compatible endpoint ---
# CUSTOM_BASE_URL=http://localhost:1234/v1
# CUSTOM_MODEL=llama-3.3-70b

# --- Premium Tools (optional) ---
EXA_API_KEY=your-exa-key
FIRECRAWL_API_KEY=your-firecrawl-key

# --- Composio (Skills: Gmail, Google Drive, Slack, …) ---
# Get a key at https://app.composio.dev — must live in the **Python backend** env / repo-root .env
# (the Next.js app only proxies to the backend; it does not read this file).
COMPOSIO_API_KEY=your-composio-api-key
# HS256 (legacy JWT secret): set from Supabase → Settings → API → JWT Secret so the backend can verify tokens.
# ES256 / asymmetric projects: leave unset; Koraku verifies via JWKS at ``{iss}/.well-known/jwks.json`` (from the token).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Automations (Python API + scheduler): PostgREST to ``koraku_automation`` / ``koraku_automation_run``.
# Use the same project URL as the web app; service role is **server-only** (never in NEXT_PUBLIC_*).
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Optional fallback Composio entity id when no signed-in user (scripts / legacy only)
# COMPOSIO_USER_ID=koraku-local

# --- Context (optional) ---
# Larger tool payloads (e.g. verbose Composio Gmail) need a higher cap before truncation on the next model turn.
# MAX_TOOL_RESULT_CHARS=48000

PORT=8000

# --- Python API scaling (optional; not required for single-worker dev) ---
# Koraku does not require Redis on the Python server today. Add Redis (or Upstash REST) later if you need:
#   shared rate limits, distributed locks, cross-worker pub/sub, or a shared detached-run / SSE buffer.
# Prefer fixing event-loop blocking (Composio etc. already offloaded with asyncio.to_thread) before adding Redis.

# --- Blaxel (optional — isolated VM for chat ``execution_target=cloud``) ---
# https://docs.blaxel.ai/Sandboxes/Overview — create keys in the Blaxel console.
# Koraku copies BL_WORKSPACE + BL_API_KEY from this file into the process environment so the Blaxel SDK sees them.
# BLAXEL_CLOUD_SANDBOX_ENABLED=true
# BL_WORKSPACE=your-workspace
# BL_API_KEY=your-api-key
# BLAXEL_SANDBOX_IMAGE=blaxel/base-image:latest
# BLAXEL_SANDBOX_REGION=us-pdx-1
# BLAXEL_SANDBOX_MEMORY_MB=512
# BLAXEL_SANDBOX_WORKDIR=/tmp
# Optional: Blaxel per-user paths when calling the API without a browser JWT (scripts only; signed-in users use Supabase ``sub``).
# KORAKU_CLOUD_USER_ID=my-stable-id

# --- Next.js web app (create web/.env.local) — Supabase Auth + Data API + optional Redis ---
# Supabase → Settings → API:
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Chat tables + RLS: from web/ run `supabase link --project-ref <ref>` once, then `npm run db:migrate`
# (runs `supabase db push`). Migrations live in web/supabase/migrations/.
# Enable Google/GitHub under Authentication → Providers and add redirect URL:
#   http://localhost:3000/auth/callback   (and your production origin + /auth/callback)
# Optional: Redis for chat thread list cache (pick one)
# Upstash REST (recommended on Vercel / serverless) — from Upstash console:
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
# Or TCP Redis (local, Docker, ElastiCache, etc.):
# REDIS_URL=redis://localhost:6379
# Signed-in users: chats persist to Supabase (chat_thread / chat_message) via Next /api/chat/* after migrations.
# Personalization (Memory / Soul / display name) uses koraku_personalization when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set on the Python API (same migrations).

# --- Web chat streaming (``web/.env.local``) ---
# Default: direct ``POST /koraku-api/stream`` (lowest latency). Set to ``1`` to use
# ``POST /koraku-api/runs`` + subscribe (same worker must serve start + stream; tab-close resume of in-flight runs):
# NEXT_PUBLIC_KORAKU_DETACHED_CHAT=1

